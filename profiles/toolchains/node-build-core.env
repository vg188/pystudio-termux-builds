PROFILE_SLUG=node-build-core
PROFILE_NAME="Node.js Native Build Core"
PROFILE_SOURCE_KEY=nodejs
DEFAULT_PACKAGES="libc++ ca-certificates zlib openssl c-ares libicu libsqlite libffi nodejs npm python python-pip build-essential make cmake ninja pkg-config binutils ndk-sysroot libllvm python-cmake"
REUSE_PACKAGE_SETS="cpp python nodejs"
FORCE_BUILD_DEPENDENCIES=true
