From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@local>
Date: Mon, 22 Jun 2026 19:29:47 +0800
Subject: [PATCH 12/16] ci: harden source download retries


diff --git a/scripts/build/termux_download.sh b/scripts/build/termux_download.sh
index b3205cd3da199d2a5b0c16ccf892a75289d93592..c663439c890e1923d925056b6f30e412ee15c657 100755
--- a/scripts/build/termux_download.sh
+++ b/scripts/build/termux_download.sh
@@ -37,11 +37,11 @@ termux_download() {
 	local TMPFILE
 	local -a CURL_OPTIONS=(
 		--fail               # Consider 4xx and 5xx responses as failures
-		--retry 5            # Retry up to 5 times on transient failures
+		--retry 15           # Retry up to 15 times on transient failures
 		--retry-connrefused  # Also retry on refused connections
-		--retry-delay 5      # Wait 5 seconds between retries
+		--retry-delay 10     # Wait 10 seconds between retries
 		--connect-timeout 30 # Wait at most 30 seconds for a connection to be established
-		--retry-max-time 120 # Stop retrying if it's still failing after 120 seconds
+		--retry-max-time 600 # Stop retrying if it's still failing after 10 minutes
 		--speed-limit 1000   # Expect at least 1000 Bytes per second
 		--speed-time 60      # Fail if the minimum speed isn't met for at least 60 seconds
 		--location           # Follow redirects
@@ -54,7 +54,7 @@ termux_download() {
 	echo "Downloading ${URL}"
 	if ! curl "${CURL_OPTIONS[@]}" --output "$TMPFILE" "$URL"; then
 		local error=1
-		local retry=2
+		local retry=5
 		local delay=60
 		local try
 		for (( try=1; try <= retry; try++ )); do
-- 
