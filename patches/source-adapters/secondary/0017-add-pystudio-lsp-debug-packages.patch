diff --git a/packages/debugpy/build.sh b/packages/debugpy/build.sh
new file mode 100644
index 0000000000..1111111111
--- /dev/null
+++ b/packages/debugpy/build.sh
@@ -0,0 +1,42 @@
+TERMUX_PKG_HOMEPAGE=https://github.com/microsoft/debugpy
+TERMUX_PKG_DESCRIPTION="Python debugger implementation for Debug Adapter Protocol"
+TERMUX_PKG_LICENSE="MIT"
+TERMUX_PKG_MAINTAINER="@pystudio"
+TERMUX_PKG_VERSION=1.8.21
+TERMUX_PKG_SRCURL=https://files.pythonhosted.org/packages/f2/aa/12037145b7a56eaa5b29b41872f7a21b538e807e13f32c4d3c46e59be084/debugpy-${TERMUX_PKG_VERSION}.tar.gz
+TERMUX_PKG_SHA256=a3c53278e84c94e11bd87c53970ec391d1a67396c8b22609fcac576520e611a6
+TERMUX_PKG_DEPENDS="python, python-pip"
+TERMUX_PKG_PYTHON_COMMON_BUILD_DEPS="setuptools, wheel"
+TERMUX_PKG_BUILD_IN_SRC=true
+TERMUX_PKG_PLATFORM_INDEPENDENT=true
+
+termux_step_pre_configure() {
+	# Avoid accidentally packaging host-built pydevd extension modules.
+	export SKIP_CYTHON_BUILD=1
+
+	local srcdir="${TERMUX_PKG_SRCDIR:-$PWD}"
+	python3 - "$srcdir" <<'PY'
+import sys
+from pathlib import Path
+
+setup = Path(sys.argv[1]) / "setup.py"
+text = setup.read_text()
+needle = '''            subprocess.check_call([
+                sys.executable,
+                os.path.join(PYDEVD_ROOT, "setup_pydevd_cython.py"),
+                "build_ext",
+                "--inplace",
+            ])'''
+replacement = '''            if not os.getenv("SKIP_CYTHON_BUILD"):
+                subprocess.check_call([
+                    sys.executable,
+                    os.path.join(PYDEVD_ROOT, "setup_pydevd_cython.py"),
+                    "build_ext",
+                    "--inplace",
+                ])'''
+if replacement not in text:
+    if needle not in text:
+        raise SystemExit("debugpy setup.py Cython build block not found")
+    setup.write_text(text.replace(needle, replacement))
+PY
+}
diff --git a/packages/pyright/build.sh b/packages/pyright/build.sh
new file mode 100644
index 0000000000..1111111111
--- /dev/null
+++ b/packages/pyright/build.sh
@@ -0,0 +1,34 @@
+TERMUX_PKG_HOMEPAGE=https://microsoft.github.io/pyright/
+TERMUX_PKG_DESCRIPTION="Static type checker and language server for Python"
+TERMUX_PKG_LICENSE="MIT"
+TERMUX_PKG_MAINTAINER="@pystudio"
+TERMUX_PKG_VERSION=1.1.410
+TERMUX_PKG_SRCURL=https://registry.npmjs.org/pyright/-/pyright-${TERMUX_PKG_VERSION}.tgz
+TERMUX_PKG_SHA256=4d6b7a25f9617ea8ff7b2e98cd87c146d132a95cbfb29bf58bd638018a76ac48
+TERMUX_PKG_DEPENDS="nodejs | nodejs-lts"
+TERMUX_PKG_BUILD_IN_SRC=true
+TERMUX_PKG_PLATFORM_INDEPENDENT=true
+
+termux_step_configure() {
+	:
+}
+
+termux_step_make() {
+	:
+}
+
+termux_step_make_install() {
+	local dest="$TERMUX_PREFIX/lib/node_modules/pyright"
+	rm -rf "$dest"
+	mkdir -p "$dest"
+
+	cp -a . "$dest"
+	chmod +x "$dest/index.js" "$dest/langserver.index.js"
+	for script in "$dest/index.js" "$dest/langserver.index.js"; do
+		sed -i "1s@^#!.*node.*@#!/usr/bin/env node@" "$script"
+	done
+
+	mkdir -p "$TERMUX_PREFIX/bin"
+	ln -sfr "$dest/index.js" "$TERMUX_PREFIX/bin/pyright"
+	ln -sfr "$dest/langserver.index.js" "$TERMUX_PREFIX/bin/pyright-langserver"
+}
